{
  "name": "kolshek",
  "version": "0.4.8",
  "description": "CLI tool for tracking finances from Israeli banks and credit cards (כל שקל)",
  "type": "module",
  "bin": {
    "kolshek": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build:css": "tailwindcss -i src/web/styles.css -o src/web/dist/styles.css --minify",
    "dev:css": "tailwindcss -i src/web/styles.css -o src/web/dist/styles.css --watch",
    "dev:web": "vite --config src/web/app/vite.config.ts",
    "build:web": "vite build --config src/web/app/vite.config.ts",
    "prebuild": "npm run build:web && tsx scripts/generate-web-embed.ts && tsx scripts/generate-plugin-embed.ts",
    "build": "tsc"
  },
  "keywords": [
    "israel",
    "finance",
    "banking",
    "credit-card",
    "cli",
    "scraper"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.17.0",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.4.0",
    "class-variance-authority": "^0.7.1",
    "cli-table3": "^0.6.0",
    "clsx": "^2.1.1",
    "commander": "^13.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.0.0",
    "debug": "^4.4.3",
    "env-paths": "^3.0.0",
    "express": "^4.21.2",
    "israeli-bank-scrapers-core": "github:Isaac-D20/israeli-bank-scrapers",
    "lucide-react": "^0.577.0",
    "ora": "^8.0.0",
    "puppeteer-core": "^24.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.1",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "smol-toml": "^1.0.0",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.19.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.8"
  },
  "trustedDependencies": [],
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "@swc/core@1.15.40": true,
    "better-sqlite3@12.10.0": true,
    "esbuild@0.28.1": true,
    "puppeteer@24.43.1": true
  }
}
