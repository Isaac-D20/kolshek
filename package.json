{
  "name": "kolshek",
  "version": "0.4.7",
  "description": "CLI tool for tracking finances from Israeli banks and credit cards (כל שקל)",
  "type": "module",
  "bin": {
    "kolshek": "./src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build:css": "bunx @tailwindcss/cli -i src/web/styles.css -o src/web/dist/styles.css --minify",
    "dev:css": "bunx @tailwindcss/cli -i src/web/styles.css -o src/web/dist/styles.css --watch",
    "dev:web": "bun --bun vite --config src/web/app/vite.config.ts",
    "build:web": "bun --bun vite build --config src/web/app/vite.config.ts",
    "prebuild": "bun run build:web && bun scripts/generate-web-embed.ts && bun scripts/generate-plugin-embed.ts",
    "build": "bun build ./src/cli/index.ts --compile --outfile dist/kolshek",
    "build:windows-x64": "bun build ./src/cli/index.ts --compile --target=bun-windows-x64 --outfile dist/kolshek-windows-x64.exe",
    "build:linux-x64": "bun build ./src/cli/index.ts --compile --target=bun-linux-x64 --outfile dist/kolshek-linux-x64",
    "build:linux-arm64": "bun build ./src/cli/index.ts --compile --target=bun-linux-arm64 --outfile dist/kolshek-linux-arm64",
    "build:macos-x64": "bun build ./src/cli/index.ts --compile --target=bun-darwin-x64 --outfile dist/kolshek-macos-x64",
    "build:macos-arm64": "bun build ./src/cli/index.ts --compile --target=bun-darwin-arm64 --outfile dist/kolshek-macos-arm64"
  },
  "keywords": [
    "israel",
    "finance",
    "banking",
    "credit-card",
    "cli",
    "scraper"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "chalk": "^5.4.0",
    "class-variance-authority": "^0.7.1",
    "cli-table3": "^0.6.0",
    "clsx": "^2.1.1",
    "commander": "^13.0.0",
    "date-fns": "^4.0.0",
    "env-paths": "^3.0.0",
    "israeli-bank-scrapers-core": "6.7.1",
    "lucide-react": "^0.577.0",
    "ora": "^8.0.0",
    "puppeteer-core": "^24.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.1",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "smol-toml": "^1.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "better-sqlite3": "^12.6.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "trustedDependencies": []
}
